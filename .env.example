WWEBJS_TEST_REMOTE_ID=XXXXXXXXXX@c.us
WWEBJS_TEST_CLIENT_ID=authenticated

# Provedor de IA: auto | openai | groq | gemini
AI_PROVIDER=auto
AI_PROBE_RETRIES=3
AI_PROBE_TIMEOUT_MS=35000
OPENAI_API_KEY=sua_chave_openai_aqui
OPENAI_MODEL=gpt-4o-mini
OPENAI_SPAM_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Bot Groq (principal recomendado)
GROQ_API_KEY=sua_chave_aqui
# llama-3.3-70b-versatile = recomendado (assistente + documentos)
# llama-3.1-8b-instant = mais rápido, menos preciso
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=700
GROQ_TEMPERATURE=0.65
GROQ_TEMPERATURE_FACTUAL=0.35
GROQ_TEMPERATURE_CREATIVE=0.8
GROQ_MAX_RETRIES=3
GROQ_REQUEST_TIMEOUT_MS=45000
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
MEDIA_MAX_BYTES=26214400

# Gemini — fallback quando Groq/OpenAI falharem ou acabarem quota
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SPAM_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# Busca semântica em documentos
# auto = OpenAI (se AI_PROVIDER=openai) ou Groq; se indisponível, TF-IDF local
SEMANTIC_SEARCH_ENABLED=true
SEMANTIC_SEARCH_MODE=auto
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GROQ_EMBEDDING_MODEL=nomic-embed-text-v1_5
SEMANTIC_SEARCH_MIN_SIMILARITY=0.42
SEMANTIC_SEARCH_LOCAL_MIN_SCORE=0.08
SEMANTIC_SEARCH_TOP_K=12
SEMANTIC_SEARCH_KEYWORD_WEIGHT=0.4
SEMANTIC_SEARCH_SEMANTIC_WEIGHT=0.6

# Modo só RAG: sem resultado na busca de documento/e-mail, resposta fixa (sem chamar IA)
RAG_ONLY_MODE=true

# Filtro de spam (faturas automáticas, propaganda, ofertas)
SPAM_FILTER_ENABLED=true
SPAM_FILTER_AI=true
SPAM_FILTER_AI_MIN_SCORE=2
GROQ_SPAM_MODEL=llama-3.1-8b-instant

# Pasta com documentos que a IA pode consultar e enviar
DOCS_ROOT=./documentos

# Histórico de conversa (mensagens enviadas à IA)
HISTORY_LIMIT_REGISTERED=40
HISTORY_LIMIT_GUEST=12

# Aguarda mensagens seguidas antes de responder (ms)
MESSAGE_DEBOUNCE_MS=2000
MESSAGE_DEBOUNCE_GREETING_MS=800

# Performance — busca e PDFs na rede
PDF_ENRICH_MAX_ON_SEARCH=2
PDF_READ_TIMEOUT_MS=8000
SEARCH_SKIP_SEMANTIC_MIN_KEYWORD_SCORE=6
SEMANTIC_SEARCH_TIMEOUT_MS=8000

# Reindexar documentos automaticamente (ms, 0 = desligado)
CATALOG_REFRESH_MS=3600000

# Reconexão WhatsApp após queda (ms)
RECONNECT_DELAY_MS=15000

# Navegador Puppeteer (false = janela visível, útil para depurar)
PUPPETEER_HEADLESS=false
WA_AUTH_TIMEOUT_MS=120000
WA_INIT_RETRIES=4
WA_INIT_RETRY_DELAY_MS=8000

# Expediente (segunda a sexta)
TIMEZONE=America/Sao_Paulo
BUSINESS_START=07:30
BUSINESS_END=17:15
BUSINESS_DAYS=1,2,3,4,5

# Seu WhatsApp (55 + DDD + número) — use !meunumero no bot
ADMIN_PHONE=

# Outlook — com = app Outlook aberto no Windows | graph = API Azure | auto = detecta
OUTLOOK_MODE=com
OUTLOOK_MAX_EMAILS=8
OUTLOOK_USER_EMAIL=tecnologia@exemplo.com.br

# Outlook Graph API (só se OUTLOOK_MODE=graph)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=common
OUTLOOK_REFRESH_TOKEN=
